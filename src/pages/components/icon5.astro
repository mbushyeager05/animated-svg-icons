// empty frontmatter for future use
---

<!-- House icon from Lucide -->

  <svg id="house" xmlns="http://www.w3.org/2000/svg" width="160" height="160" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path id="structure" d="M8.5 21H5a2 2 0 0 1-2-2v-9a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2h-5a2 2 0 0 1-2-2v-2" stroke="#666767"/>
    <path id="outlet"    d="M15 12a1 1 0 0 1 1 1v2a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-2a1 1 0 0 1 1-1z" stroke="#666767"/>
    <path id="prong-l"   d="M10 12V8.964" stroke="#666767"/>
    <path id="prong-r"   d="M14 12V8.964" stroke="#666767"/>
  </svg


<!-- GSAP Scripting -->
<script>
    import gsap from 'gsap';

   const structureLen = document.querySelector('#structure').getTotalLength();
 
    gsap.set('#structure', { strokeDasharray: structureLen, strokeDashoffset: structureLen, opacity: 1 });
    gsap.set(['#outlet', '#prong-l', '#prong-r', '#structure'], { opacity: 0 });
 
    gsap.timeline({ repeat: -1, repeatDelay: 0.8 })
 
      // Plug
      .to('#outlet',  { opacity: 1, duration: 0.3, ease: "power2.out" })
      .to('#prong-l', { opacity: 1, duration: 0.3, ease: "power2.out" })
      .to('#prong-r', { opacity: 1, duration: 0.3, ease: "power2.out" })
 
      // House 
      .to('#structure', { opacity: 1, duration: 0.01 }, "+=0.2")
      .to('#structure', { strokeDashoffset: 0, duration: 1.2, ease: "power2.out" })
 
      // green
      .to(['#outlet', '#prong-l', '#prong-r', '#structure'], { attr: { stroke: '#22c55e' }, duration: 0.4 })
      .to('#house', { scale: 1.08, transformOrigin: "50% 50%", duration: 0.25, ease: "power2.out" })
      .to('#house', { scale: 1,    transformOrigin: "50% 50%", duration: 0.35, ease: "power2.in" })
 
      // Reset
      .to(['#outlet', '#prong-l', '#prong-r', '#structure'], { opacity: 0, attr: { stroke: '#666767' }, duration: 0.4 })
      .set('#structure', { strokeDashoffset: structureLen });
</script>
