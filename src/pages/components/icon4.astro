---

<!--  Batteryicon from Lucide -->

<svg id="battery" xmlns="http://www.w3.org/2000/svg" width="160" height="160" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <rect id="body"  x="2" y="6" width="16" height="12" rx="2" stroke="#666767"/>
    <path id="tip"   d="M22 14v-4"  stroke="#666767"/>
    <path id="bar-1" d="M6 10v4"   stroke="#666767"/>
    <path id="bar-2" d="M10 10v4"  stroke="#666767"/>
    <path id="bar-3" d="M14 10v4"  stroke="#666767"/>
  </svg>


<!-- GSAP Scripting -->
<script>
    import gsap from 'gsap';

      const bars = ['#bar-1', '#bar-2', '#bar-3'];
 
    gsap.set(bars, { attr: { stroke: '#d1d5db' } });
    gsap.set('#body', { attr: { stroke: '#d1d5db' } });
 
    gsap.timeline({ repeat: -1, repeatDelay: 0.5 })
      .to('#bar-1',  { attr: { stroke: '#DD0426' }, duration: 0.4, ease: "power2.out" })
      .to('#body',   { attr: { stroke: '#22c55e' }, duration: 0.3 }, "<")
      .to('#bar-2',  { attr: { stroke: '#F4B942' }, duration: 0.4, ease: "power2.out" }, "+=0.4")
      .to('#bar-3',  { attr: { stroke: '#22c55e' }, duration: 0.4, ease: "power2.out" }, "+=0.4")
      .to('#battery', { scale: 1.08, transformOrigin: "50% 50%", duration: 0.3, ease: "power2.out" }, "+=0.2")
      .to(['#body', '#tip', ...bars], { attr: { stroke: '#86efac' }, duration: 0.3 }, "<")
      .to('#battery', { scale: 1, transformOrigin: "50% 50%", duration: 0.4, ease: "power2.in" }, "+=0.4")
      .to(['#body', '#tip', ...bars], { attr: { stroke: '#d1d5db' }, duration: 0.3 }, "+=0.3");


</script>
